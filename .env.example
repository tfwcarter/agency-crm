DATABASE_URL=

# Only needed if DATABASE_URL points to a remote libsql/Turso database
# (e.g. libsql://your-db.turso.io). Leave unset for local file:./dev.db.
DATABASE_AUTH_TOKEN=

# Auth.js (NextAuth v5) session encryption secret — regenerate for production.
AUTH_SECRET=

# Groq API key — FREE, no credit card required. Powers AI Sales Assistant, AI Insights,
# AI Coach, AI Website Analyzer pitches, AI Website Builder copy, and Marketing Reports
# AI summaries. Every other CRM feature works without it.
# Get a free key in ~30 seconds at https://console.groq.com/keys
GROQ_API_KEY=

# Optional: Anthropic API key — used instead of Groq if you'd rather pay for Claude.
# Not required; Groq above is free and used automatically when set.
# Get a key at https://console.anthropic.com
ANTHROPIC_API_KEY=

# Optional: Google PageSpeed Insights API key improves the AI Website Analyzer's speed score
# accuracy. Falls back to a heuristic score without it.
# https://developers.google.com/speed/docs/insights/v5/get-started
PAGESPEED_API_KEY=

# Optional: Stripe secret key — required to accept real online invoice payments in Invoices
# and the Client Portal. Invoices work fully without it (manual mark-as-paid).
STRIPE_SECRET_KEY=
